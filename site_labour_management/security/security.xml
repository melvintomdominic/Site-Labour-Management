<odoo>
    <record id="group_site_labour_supervisor" model="res.groups">
        <field name="name">Site Labour Supervisor</field>
        <field name="category_id" ref="base.module_category_project_management"/>
    </record>

    <record id="group_site_labour_admin" model="res.groups">
        <field name="name">Site Labour Admin</field>
        <field name="category_id" ref="base.module_category_project_management"/>
        <field name="implied_ids" eval="[(4, ref('group_site_labour_supervisor'))]"/>
    </record>

    <record id="group_site_labour_billing" model="res.groups">
        <field name="name">Site Labour Billing</field>
        <field name="category_id" ref="base.module_category_accounting"/>
    </record>
</odoo>
