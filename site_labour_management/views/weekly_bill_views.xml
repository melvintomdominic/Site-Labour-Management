<odoo>
    <record id="view_site_labour_weekly_bill_tree" model="ir.ui.view">
        <field name="name">site.labour.weekly.bill.tree</field>
        <field name="model">site.labour.weekly.bill</field>
        <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="week_start"/>
                    <field name="week_end"/>
                    <field name="analytic_account_id"/>
                    <field name="billing_frequency"/>
                <field name="amount_total"/>
                <field name="state"/>
                <field name="move_id"/>
            </list>
        </field>
    </record>

    <record id="view_site_labour_weekly_bill_form" model="ir.ui.view">
        <field name="name">site.labour.weekly.bill.form</field>
        <field name="model">site.labour.weekly.bill</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_vendor_bill" type="object" string="Create Vendor Bill" class="oe_highlight" invisible="state != 'draft'" groups="site_labour_management.group_site_labour_billing"/>
                    <button name="action_assign_analytic_account" type="object" string="Assign Analytic Account"/>
                    <button name="action_pull_daily_bills" type="object" string="Pull Daily Bills"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,billed"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="partner_id"/>
                        <field name="week_start"/>
                        <field name="week_end"/>
                        <field name="analytic_account_id"/>
                        <field name="billing_frequency"/>
                        <field name="move_id" readonly="1"/>
                        <field name="amount_total" readonly="1"/>
                    </group>
                    <group>
                        <field name="sheet_ids" widget="many2many_tags"/>
                        <field name="daily_bill_ids" widget="many2many_tags"/>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="source"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_site_labour_weekly_bill" model="ir.actions.act_window">
        <field name="name">Weekly Bills</field>
        <field name="res_model">site.labour.weekly.bill</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
