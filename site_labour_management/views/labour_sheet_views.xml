<odoo>
    <record id="view_site_labour_sheet_tree" model="ir.ui.view">
        <field name="name">site.labour.sheet.tree</field>
        <field name="model">site.labour.sheet</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="attendance_type"/>
                <field name="analytic_account_id"/>
                <field name="team_leader_id"/>
                <field name="supervisor_id"/>
                <field name="total_amount"/>
                <field name="state"/>
                <field name="billing_status"/>
            </list>
        </field>
    </record>

    <record id="view_site_labour_sheet_form" model="ir.ui.view">
        <field name="name">site.labour.sheet.form</field>
        <field name="model">site.labour.sheet</field>
        <field name="arch" type="xml">
            <form string="Labour Sheet">
                <header>
                    <button name="action_submit" type="object" string="Submit" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'submitted'" groups="site_labour_management.group_site_labour_admin"/>
                    <button name="action_assign_analytic_account" type="object" string="Assign Analytic Account"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <group col="2">
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date"/>
                            <field name="attendance_type"/>
                            <field name="analytic_account_id" string="Project"/>
                            <field name="team_leader_id" invisible="attendance_type != 'team'" domain="[('parent_id','=',False)]"/>
                            <field name="team_labour_ids" widget="many2many_tags" invisible="attendance_type != 'team'" domain="[('parent_id','=',team_leader_id),('parent_id','!=',False)]"/>
                            <field name="supervisor_id"/>
                        </group>
                        <group>
                            <field name="latitude"/>
                            <field name="longitude"/>
                            <field name="billing_status" readonly="1"/>
                            <field name="billing_frequency"/>
                            <field name="total_amount" readonly="1"/>
                        </group>
                    </group>

                    <field name="labour_line_ids">
                        <tree editable="bottom">
                            <field name="labour_id" domain="[('parent_id','!=',False)]"/>
                            <field name="category_id"/>
                            <field name="wage"/>
                            <field name="hours"/>
                            <field name="ot_hours"/>
                            <field name="total"/>
                        </tree>
                    </field>

                    <notebook>
                        <page string="Photos">
                            <field name="photo_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="image_type"/>
                                    <field name="image" widget="image"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_site_labour_sheet_graph" model="ir.ui.view">
        <field name="name">site.labour.sheet.graph</field>
        <field name="model">site.labour.sheet</field>
        <field name="arch" type="xml">
            <graph string="Project Cost" type="bar">
                <field name="analytic_account_id"/>
                <field name="total_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_site_labour_sheet_pivot" model="ir.ui.view">
        <field name="name">site.labour.sheet.pivot</field>
        <field name="model">site.labour.sheet</field>
        <field name="arch" type="xml">
            <pivot string="Supervisor vs Cost">
                <field name="supervisor_id" type="row"/>
                <field name="analytic_account_id" type="col"/>
                <field name="total_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_site_labour_sheet" model="ir.actions.act_window">
        <field name="name">Labour Sheets</field>
        <field name="res_model">site.labour.sheet</field>
        <field name="view_mode">list,form,graph,pivot</field>
    </record>
</odoo>
