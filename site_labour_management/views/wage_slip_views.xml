<odoo>
    <record id="view_site_labour_wage_slip_tree" model="ir.ui.view">
        <field name="name">site.labour.wage.slip.tree</field>
        <field name="model">site.labour.wage.slip</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="total_amount"/>
            </list>
        </field>
    </record>

    <record id="view_site_labour_wage_slip_form" model="ir.ui.view">
        <field name="name">site.labour.wage.slip.form</field>
        <field name="model">site.labour.wage.slip</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="partner_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="weekly_bill_id"/>
                        <field name="sheet_ids" widget="many2many_tags"/>
                        <field name="total_amount" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_site_labour_wage_slip" model="ir.actions.act_window">
        <field name="name">Wage Slips</field>
        <field name="res_model">site.labour.wage.slip</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
