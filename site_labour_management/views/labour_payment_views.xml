<odoo>
    <record id="view_site_labour_payment_tree" model="ir.ui.view">
        <field name="name">site.labour.payment.tree</field>
        <field name="model">site.labour.payment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="payment_date"/>
                <field name="journal_id"/>
                <field name="total_amount"/>
                <field name="state"/>
                <field name="move_id"/>
            </list>
        </field>
    </record>

    <record id="view_site_labour_payment_form" model="ir.ui.view">
        <field name="name">site.labour.payment.form</field>
        <field name="model">site.labour.payment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_post" type="object" string="Post" class="btn-primary" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="payment_date"/>
                        <field name="journal_id"/>
                        <field name="total_amount" readonly="1"/>
                        <field name="move_id" readonly="1"/>
                        <field name="remarks"/>
                    </group>
                    <field name="line_ids">
                        <tree editable="bottom">
                            <field name="partner_id" domain="[('is_team_leader','=',True)]"/>
                            <field name="amount"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_site_labour_payment" model="ir.actions.act_window">
        <field name="name">Labour Payments</field>
        <field name="res_model">site.labour.payment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
