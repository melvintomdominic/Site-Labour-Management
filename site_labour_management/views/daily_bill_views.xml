<odoo>
    <record id="view_site_labour_daily_bill_search" model="ir.ui.view">
        <field name="name">site.labour.daily.bill.search</field>
        <field name="model">site.labour.daily.bill</field>
        <field name="arch" type="xml">
            <search>
                <field name="date"/>
                <field name="partner_id" domain="[('parent_id','=',False)]"/>
                <filter name="today" string="Today" domain="[('date','=',context_today())]"/>
            </search>
        </field>
    </record>

    <record id="view_site_labour_daily_bill_list" model="ir.ui.view">
        <field name="name">site.labour.daily.bill.list</field>
        <field name="model">site.labour.daily.bill</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id" domain="[('parent_id','=',False)]"/>
                <field name="analytic_account_id"/>
                <field name="total_amount"/>
                <field name="state"/>
                <field name="move_id"/>
            </list>
        </field>
    </record>

    <record id="view_site_labour_daily_bill_form" model="ir.ui.view">
        <field name="name">site.labour.daily.bill.form</field>
        <field name="model">site.labour.daily.bill</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_post" type="object" string="Post" class="oe_highlight" invisible="state != 'confirmed'" groups="site_labour_management.group_site_labour_billing"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,posted"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="date"/>
                        <field name="partner_id" domain="[('parent_id','=',False)]"/>
                        <field name="analytic_account_id" string="Project"/>
                        <field name="labour_sheet_ids" widget="many2many_tags"/>
                        <field name="move_id" readonly="1"/>
                        <field name="total_amount" readonly="1"/>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="labour_id"/>
                            <field name="work_type"/>
                            <field name="quantity"/>
                            <field name="rate"/>
                            <field name="amount" readonly="1"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_site_labour_daily_bill" model="ir.actions.act_window">
        <field name="name">Daily Bills</field>
        <field name="res_model">site.labour.daily.bill</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_site_labour_daily_bill_search"/>
    </record>
</odoo>
