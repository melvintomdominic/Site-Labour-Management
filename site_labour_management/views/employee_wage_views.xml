<odoo>
    <record id="view_site_labour_employee_wage_list" model="ir.ui.view">
        <field name="name">site.labour.employee.wage.list</field>
        <field name="model">site.labour.employee.wage</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="wage_rate"/>
                <field name="effective_date"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_site_labour_employee_wage_form" model="ir.ui.view">
        <field name="name">site.labour.employee.wage.form</field>
        <field name="model">site.labour.employee.wage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="wage_rate"/>
                        <field name="effective_date"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_site_labour_employee_wage" model="ir.actions.act_window">
        <field name="name">Employee Wages</field>
        <field name="res_model">site.labour.employee.wage</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
